# =============================================================================
# VoiceMemo AI — copy to .env.local and fill in your values (never commit .env.local)
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_MCP_EVENTS_URL=http://localhost:3001/events
NEXT_PUBLIC_LOG_RELAY=false

# --- Agora RTC + Conversational AI ---
NEXT_PUBLIC_AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=
# Pipeline ID from Agora Console → Project → Agents (NOT customer id/secret)
AGORA_AGENT_ID=

# MCP endpoint Agora agent calls (use ngrok HTTPS URL in dev: https://xxx.ngrok-free.app/mcp)
MCP_SERVER_URL=http://localhost:3001/mcp
MCP_SERVER_PORT=3001

# --- Voice profile: fast | balanced ---
AGORA_VOICE_PROFILE=fast
# Optional TTS (MiniMax via Agora)
AGORA_TTS_VOICE_ID=Arrogant_Miss
AGORA_USE_STUDIO_VOICE=false
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# --- LLM (Agora agent BYOK) ---
OPENAI_API_KEY=

# --- Database: mock file store for local dev ---
USE_MOCK_DB=true

# --- Couchbase Capella (when USE_MOCK_DB=false) ---
COUCHBASE_CONNECTION_STRING=
COUCHBASE_USERNAME=
COUCHBASE_PASSWORD=
COUCHBASE_BUCKET=voicememo
COUCHBASE_SCOPE=notes
COUCHBASE_COLLECTION=entries

# --- Optional: Gemini (if wired outside Agora preset) ---
# GEMINI_API_KEY=
