#!/bin/sh
# Strip Cursor attribution trailers before commit message is finalized.
MSG_FILE="$1"
[ -f "$MSG_FILE" ] || exit 0

case "$(uname -s)" in
  Darwin)
    sed -i '' '/cursoragent@cursor\.com/d' "$MSG_FILE"
    sed -i '' '/Co-authored-by: Cursor/d' "$MSG_FILE"
    sed -i '' '/Made-with: Cursor/d' "$MSG_FILE"
    sed -i '' '/Made with Cursor/d' "$MSG_FILE"
    ;;
  *)
    sed -i '/cursoragent@cursor\.com/d' "$MSG_FILE"
    sed -i '/Co-authored-by: Cursor/d' "$MSG_FILE"
    sed -i '/Made-with: Cursor/d' "$MSG_FILE"
    sed -i '/Made with Cursor/d' "$MSG_FILE"
    ;;
esac

exit 0
